---
import Marquee from "./Marquee.astro";

const frameworks = ["Android", "Flutter", "Compose", "React", "Spring"];
const languages = ["Java", "Kotlin", "Dart", "Python", "TypeScript"];
---

<section id="stack" class="relative py-32 md:py-44">
  <div class="mx-auto max-w-6xl px-6 lg:px-10">
    <div class="mb-16 md:mb-20 grid gap-10 md:grid-cols-12">
      <div class="md:col-span-7">
        <p data-reveal class="reveal text-[12px] font-medium uppercase tracking-[0.22em] text-white/45">
          — The toolkit
        </p>
        <h2
          data-reveal
          class="reveal mt-5 font-display tracking-[-0.035em] text-balance text-white"
          style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05; font-weight: 600;"
        >
          Frameworks I reach for.<br/>
          <span class="text-white/35">Languages I think in.</span>
        </h2>
      </div>
      <p
        data-reveal
        class="reveal md:col-span-5 self-end max-w-md text-[15px] leading-relaxed text-white/55"
      >
        A small, sharp toolkit chosen for what it lets me build, not for the
        novelty. Each tool earns its keep across multiple projects and shipped
        products.
      </p>
    </div>
  </div>

  <div data-reveal class="reveal space-y-4 md:space-y-5">
    <Marquee items={frameworks} duration={38} />
    <Marquee items={languages} duration={45} reverse={true} />
  </div>
</section>
