---
---

<section
  id="top"
  class="relative isolate flex min-h-[100svh] items-center overflow-hidden pt-20"
>
  <div class="absolute inset-0 grid-bg pointer-events-none" aria-hidden="true"></div>

  <div
    class="absolute inset-x-0 top-1/4 mx-auto h-[420px] max-w-3xl rounded-full opacity-60 blur-3xl pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(closest-side, rgba(122,162,255,0.32), transparent 75%);"
  ></div>

  <div class="absolute noise" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 lg:px-10">
    <div class="flex flex-col items-start gap-6 md:gap-8">
      <div data-reveal class="reveal inline-flex items-center gap-2.5 rounded-full glass px-3.5 py-1.5">
        <span class="relative grid h-2 w-2">
          <span class="absolute inset-0 animate-ping rounded-full bg-emerald-400/60"></span>
          <span class="relative h-full w-full rounded-full bg-emerald-400"></span>
        </span>
        <span class="text-[12px] font-medium tracking-tight text-white/70">
          Hi, I'm Qi — available for new projects, 2026
        </span>
      </div>

      <h1
        data-reveal
        class="reveal text-balance font-display tracking-[-0.04em] text-white"
        style="font-size: clamp(2.4rem, 6.4vw, 5.5rem); font-weight: 600; line-height: 0.98;"
      >
        <span class="block gradient-text">Software engineer</span>
        <span class="block text-white/35">building products across</span>
        <span class="block"><em class="not-italic bg-gradient-to-r from-[#7aa2ff] via-white to-[#a8c4ff] bg-clip-text text-transparent">every surface</em>.</span>
      </h1>

      <p
        data-reveal
        class="reveal max-w-xl text-pretty text-base md:text-lg leading-relaxed text-white/55"
      >
        Full-stack engineer based in Canada — designing and shipping
        cross-platform mobile apps, fast and accessible web experiences,
        and resilient backend systems that quietly do the work.
      </p>

      <div data-reveal class="reveal flex flex-wrap items-center gap-3">
        <a
          href="#work"
          class="group magnetic inline-flex items-center gap-2 rounded-full bg-white px-5 py-3 text-[14px] font-medium text-black transition-all duration-500 hover:scale-[1.02]"
        >
          <span>Explore the work</span>
          <span class="grid h-5 w-5 place-items-center rounded-full bg-black/10 transition-transform duration-500 group-hover:translate-x-0.5">
            <svg width="10" height="10" viewBox="0 0 12 12">
              <path d="M2 6h7m0 0L6 3m3 3L6 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </span>
        </a>
        <a
          href="#contact"
          class="magnetic inline-flex items-center gap-2 rounded-full glass px-5 py-3 text-[14px] font-medium text-white/85 transition-all duration-500 hover:bg-white/[0.07] hover:text-white"
        >
          <span>Say hello</span>
        </a>
      </div>
    </div>

    <div
      data-reveal
      class="reveal absolute inset-x-0 bottom-8 hidden md:flex items-center justify-center gap-2"
      style="transition-delay: 600ms;"
    >
      <div class="flex flex-col items-center gap-2 text-white/35">
        <span class="text-[11px] font-medium uppercase tracking-[0.18em]">Scroll</span>
        <span class="h-9 w-[1px] bg-gradient-to-b from-white/40 to-transparent"></span>
      </div>
    </div>
  </div>
</section>
