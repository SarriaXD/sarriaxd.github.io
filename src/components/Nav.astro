---
const links = [
  { href: "#work", label: "Work" },
  { href: "#stack", label: "Stack" },
  { href: "#craft", label: "Craft" },
  { href: "#contact", label: "Contact" },
];
---

<nav
  data-nav
  class="fixed top-0 inset-x-0 z-50 transition-[backdrop-filter,background-color,border-color] duration-500"
>
  <div class="mx-auto max-w-6xl px-6 lg:px-10">
    <div class="flex h-16 items-center justify-between">
      <a href="#top" class="group inline-flex items-center gap-2.5">
        <span class="relative grid h-7 w-7 place-items-center rounded-md bg-white/[0.04] ring-1 ring-white/10 transition-all duration-500 group-hover:ring-white/25">
          <span class="text-[13px] font-semibold tracking-tight bg-gradient-to-b from-white to-white/60 bg-clip-text text-transparent">Q</span>
        </span>
        <span class="text-[13px] font-medium tracking-tight text-white/80 group-hover:text-white transition-colors">Qi Wang</span>
      </a>

      <ul class="hidden md:flex items-center gap-1">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="relative inline-flex items-center px-3 py-2 text-[13px] font-medium text-white/55 hover:text-white transition-colors duration-300"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href="#contact"
        class="group inline-flex items-center gap-2 rounded-full bg-white text-black px-4 py-2 text-[13px] font-medium tracking-tight transition-all duration-500 hover:bg-white/90 hover:scale-[1.02]"
      >
        <span>Get in touch</span>
        <svg width="12" height="12" viewBox="0 0 12 12" class="transition-transform duration-500 group-hover:translate-x-0.5">
          <path d="M2 6h7m0 0L6 3m3 3L6 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>("[data-nav]");
  if (nav) {
    const apply = () => {
      if (window.scrollY > 8) {
        nav.classList.add("bg-[#050608]/70", "backdrop-blur-xl", "border-b", "border-white/[0.06]");
      } else {
        nav.classList.remove("bg-[#050608]/70", "backdrop-blur-xl", "border-b", "border-white/[0.06]");
      }
    };
    apply();
    window.addEventListener("scroll", apply, { passive: true });
  }
</script>
