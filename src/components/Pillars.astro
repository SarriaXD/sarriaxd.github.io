---
const pillars = [
  {
    eyebrow: "Mobile",
    title: "Cross-platform, native-feeling.",
    body: "Flutter for one codebase, two platforms. Native Android with Jetpack Compose when the moment calls for it.",
    stack: ["Flutter", "Compose", "Android"],
    glyph: "device",
  },
  {
    eyebrow: "Web",
    title: "Fast, accessible, alive.",
    body: "React SPAs with restrained motion. Server-rendered for speed, SEO-aware, designed to feel weightless.",
    stack: ["React", "TypeScript"],
    glyph: "browser",
  },
  {
    eyebrow: "Backend",
    title: "Quiet systems that hold.",
    body: "Spring Boot services on AWS, with CI/CD that ships predictably. Built to scale before it has to.",
    stack: ["Spring", "Java", "Kotlin"],
    glyph: "server",
  },
];
---

<section id="work" class="relative py-32 md:py-44">
  <div class="mx-auto max-w-6xl px-6 lg:px-10">
    <div class="mb-16 md:mb-24 max-w-2xl">
      <p data-reveal class="reveal text-[12px] font-medium uppercase tracking-[0.22em] text-white/45">
        — Three surfaces
      </p>
      <h2
        data-reveal
        class="reveal mt-5 font-display tracking-[-0.035em] text-balance text-white"
        style="font-size: clamp(2rem, 5vw, 3.75rem); line-height: 1.05; font-weight: 600;"
      >
        <span class="text-white/35">One craft.</span><br/>
        Mobile, web, and the systems behind both.
      </h2>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {pillars.map((p, i) => (
        <article
          data-reveal
          class="reveal group relative overflow-hidden rounded-2xl glass p-7 md:p-8 transition-[transform,border-color,background-color] duration-700 hover:-translate-y-1 hover:bg-white/[0.05] hover:border-white/15"
          style={`transition-delay: ${i * 80}ms;`}
        >
          <div
            class="pointer-events-none absolute -top-24 -right-24 h-48 w-48 rounded-full opacity-0 transition-opacity duration-700 group-hover:opacity-100"
            style="background: radial-gradient(closest-side, rgba(122,162,255,0.18), transparent 70%);"
            aria-hidden="true"
          ></div>

          <div class="relative">
            <div class="mb-8 grid h-11 w-11 place-items-center rounded-xl bg-white/[0.03] ring-1 ring-white/10 text-white/80 transition-all duration-500 group-hover:bg-white/[0.06] group-hover:ring-white/20">
              {p.glyph === "device" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="6" y="2" width="12" height="20" rx="2"/>
                  <path d="M11 18h2"/>
                </svg>
              )}
              {p.glyph === "browser" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="16" rx="2"/>
                  <path d="M3 9h18"/>
                </svg>
              )}
              {p.glyph === "server" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="6" rx="1.5"/>
                  <rect x="3" y="14" width="18" height="6" rx="1.5"/>
                  <path d="M7 7h.01M7 17h.01"/>
                </svg>
              )}
            </div>

            <p class="text-[12px] font-medium uppercase tracking-[0.18em] text-white/40 mb-3">{p.eyebrow}</p>
            <h3 class="text-balance text-2xl md:text-[28px] font-display font-semibold tracking-[-0.02em] text-white leading-[1.15]">
              {p.title}
            </h3>
            <p class="mt-4 text-[15px] leading-relaxed text-white/55">{p.body}</p>

            <ul class="mt-7 flex flex-wrap gap-1.5">
              {p.stack.map((s) => (
                <li class="rounded-full border border-white/10 bg-white/[0.02] px-2.5 py-1 text-[11px] font-medium tracking-tight text-white/65">
                  {s}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
